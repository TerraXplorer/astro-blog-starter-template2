---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Markus Stoll – Microsoft 365 / Intune Consultant';
const description = 'Freelance Microsoft 365 Consultant mit Schwerpunkt Intune, Autopilot, Entra ID, Exchange Online und Modern Workplace.';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			html {
				scroll-behavior: smooth;
			}

			section {
				margin-bottom: 60px;
			}
		</style>
	</head>
	<body>
		<Header />

		<main>

			<!-- START -->
			<section id="start">
				<h1>Markus Stoll</h1>
				<p><strong>Microsoft 365 / Intune Consultant</strong></p>
				<p>
					Freelance Consultant mit Schwerpunkt Endpoint Management, Modern Workplace,
					Microsoft Intune, Windows Autopilot, Entra ID und Exchange Online.
				</p>
				<p>
					<a href="mailto:info@markusstoll.cloud">info@markusstoll.cloud</a> ·
					0151 / 400 76 528 · Bielefeld
				</p>
			</section>

			<!-- PROFIL -->
			<section id="profil">
				<h2>Profil</h2>
				<p>
					Erfahrung in der eigenverantwortlichen Betreuung und Weiterentwicklung hybrider
					Microsoft-365-Umgebungen mit ca. 500 Benutzern und über 500 Endgeräten.
					Fokus auf Intune, Autopilot, Entra ID sowie Automatisierung von Deployment-
					und Patchprozessen.
				</p>
			</section>

			<!-- LEISTUNGEN -->
			<section id="leistungen">
				<h2>Leistungen</h2>
				<ul>
					<li>Microsoft Intune: Compliance Policies, Security Baselines, App Deployment</li>
					<li>Windows Autopilot: Azure AD Join, Deployment-Prozessoptimierung</li>
					<li>Entra ID: Conditional Access, MFA, Device Compliance</li>
					<li>Exchange Online: Migration, Mailflow, Shared Mailboxes</li>
					<li>Patch Management: PatchMyPC, Windows Autopatch</li>
					<li>PowerShell-Automatisierung für Administration und Fehleranalyse</li>
				</ul>
			</section>

			<!-- PROJEKTE -->
			<section id="projekte">
				<h2>Projektbeispiele</h2>

				<h3>Betrieb und Weiterentwicklung einer Intune-Umgebung</h3>
				<ul>
					<li>Betreuung einer Umgebung mit ca. 300 Windows-, 150 iOS- und 100 macOS-Geräten</li>
					<li>Umsetzung von Compliance Policies, Security Baselines und BitLocker-Verschlüsselung</li>
					<li>Implementierung von Conditional Access mit MFA, Device Compliance und Standortanforderungen</li>
				</ul>

				<h3>Optimierung Windows Autopilot Deployment</h3>
				<ul>
					<li>Analyse und Optimierung bestehender Autopilot-Prozesse</li>
					<li>Reduktion der Bereitstellungszeit um ca. 50 %</li>
					<li>Verbesserung der Benutzerführung im Deployment-Prozess</li>
				</ul>

				<h3>Automatisiertes Patchmanagement</h3>
				<ul>
					<li>Einführung von PatchMyPC und Windows Autopatch</li>
					<li>Verwaltung von über 400 Anwendungen im automatisierten Updateprozess</li>
					<li>Reduktion manueller Aufwände und Verbesserung der Updatequalität</li>
				</ul>

				<h3>Migration Fileserver zu SharePoint Online / Teams</h3>
				<ul>
					<li>Migration im mittleren TB-Bereich für ca. 500 Benutzer</li>
					<li>Strukturierung von Berechtigungen und Datenablagen</li>
					<li>Begleitung der Anwender und Anpassung bestehender Arbeitsprozesse an M365</li>
				</ul>
			</section>

			<!-- KONTAKT -->
			<section id="kontakt">
				<h2>Kontakt</h2>
				<p>
					Für Projektanfragen:
					<a href="mailto:info@markusstoll.cloud">info@markusstoll.cloud</a>
				</p>
			</section>

		</main>

		<Footer />
	</body>
</html>

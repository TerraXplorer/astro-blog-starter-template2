---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Markus Stoll – Microsoft 365 / Intune Consultant';
const description = 'Freelance Microsoft 365 Consultant mit Schwerpunkt Intune, Autopilot, Entra ID, Exchange Online und Modern Workplace.';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={title} description={description} />
		<style>
	html {
		scroll-behavior: smooth;
		background: #0f172a;
	}

	body {
		margin: 0;
		background: #0f172a;
		color: #e5e7eb;
		font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	main {
		max-width: 1000px;
		margin: 0 auto;
		padding: 48px 20px;
	}

	section {
		margin-bottom: 80px;
		padding: 32px;
		background: #1e293b;
		border: 1px solid #334155;
		border-radius: 14px;
		scroll-margin-top: 90px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
	}

	#start {
		background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
		border-color: #334155;
	}

	#kontakt {
		min-height: 60vh;
	}

	h1,
	h2,
	h3 {
		color: #f8fafc;
		line-height: 1.2;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 3.2rem);
		margin-top: 0;
		margin-bottom: 0.4em;
	}

	h2 {
		margin-top: 0;
		font-size: 1.6rem;
	}

	h3 {
		margin-top: 2em;
		margin-bottom: 0.5em;
		font-size: 1.15rem;
	}

	p {
		color: #cbd5e1;
		font-size: 1rem;
	}

	ul {
		padding-left: 1.25rem;
	}

	li {
		margin-bottom: 0.5em;
		color: #cbd5e1;
	}

	a {
		color: #3b82f6;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	strong {
		color: #f8fafc;
	}

	@media (max-width: 720px) {
		main {
			padding: 32px 14px;
		}

		section {
			padding: 24px 20px;
			border-radius: 12px;
		}
	}
</style>
	</head>
	<body>
		<Header />

		<main>

			<!-- START -->
			<section id="start">
				<h1>Markus Stoll</h1>
				<p><strong>Microsoft 365 / Intune Consultant</strong></p>
				<p class="hero-text">
					Ich unterstütze Unternehmen bei Einführung, Betrieb und Optimierung von Microsoft 365,
					Microsoft Intune, Windows Autopilot, Entra ID, Exchange Online sowie klassischen
					Active Directory Infrastrukturen – mit Fokus auf stabile Deployments, klare Prozesse
					und automatisierte Administration.
				</p>
				<p>
					<a href="mailto:info@markusstoll.cloud">info@markusstoll.cloud</a> ·
					0151 / 400 76 528 · Bielefeld
				</p>
			</section>

			<!-- PROFIL -->
			<section id="profil">
				<h2>Profil</h2>
				<p>
					Erfahrung in der eigenverantwortlichen Betreuung und Weiterentwicklung hybrider Microsoft-365-Umgebungen mit ca. 500 Benutzern und über 500 Endgeräten. Fokus auf Intune, Autopilot, Entra ID sowie Automatisierung von Deployment- und Patchprozessen.
				</p>
				<p> </p>
				<p>
				Erfahrung in der Betreuung und Weiterentwicklung mehrerer Kundenumgebungen im Umfeld eines Microsoft-365-Dienstleisters. Zusammenarbeit mit IT-Administratoren sowie Beratung von Fachbereichen und Geschäftsführung. Umsetzung von Einführungen, Erweiterungen, Troubleshooting und Identifikation von Optimierungspotenzialen in Microsoft-365-, Intune- und hybriden Infrastrukturen.
				</p>
			</section>

			<!-- LEISTUNGEN -->
			<section id="leistungen">
				<h2>Leistungen</h2>
				<ul>
					<li>Microsoft Intune: Compliance Policies, Security Baselines, App Deployment</li>
					<li>Windows Autopilot: Azure AD Join, Deployment-Prozessoptimierung</li>
					<li>Entra ID: Conditional Access, MFA, Device Compliance</li>
					<li>Exchange Online: Migration, Mailflow, Shared Mailboxes</li>
					<li>Patch Management: PatchMyPC, Windows Autopatch</li>
					<li>PowerShell-Automatisierung für Administration und Fehleranalyse</li>
				</ul>
			</section>

			<!-- PROJEKTE -->
			<section id="projekte">
				<h2>Projektbeispiele</h2>

				<h3>Betrieb und Weiterentwicklung einer Intune-Umgebung</h3>
				<ul>
					<li>Betreuung einer Umgebung mit ca. 300 Windows-, 150 iOS- und 100 macOS-Geräten</li>
					<li>Umsetzung von Compliance Policies, Security Baselines und BitLocker-Verschlüsselung</li>
					<li>Implementierung von Conditional Access mit MFA, Device Compliance und Standortanforderungen</li>
				</ul>

				<h3>Optimierung Windows Autopilot Deployment</h3>
				<ul>
					<li>Analyse und Optimierung bestehender Autopilot-Prozesse</li>
					<li>Reduktion der Bereitstellungszeit um ca. 50 %</li>
					<li>Verbesserung der Benutzerführung im Deployment-Prozess</li>
				</ul>

				<h3>Automatisiertes Patchmanagement</h3>
				<ul>
					<li>Einführung von PatchMyPC und Windows Autopatch</li>
					<li>Verwaltung von über 400 Anwendungen im automatisierten Updateprozess</li>
					<li>Reduktion manueller Aufwände und Verbesserung der Updatequalität</li>
				</ul>

				<h3>Migration Fileserver zu SharePoint Online / Teams</h3>
				<ul>
					<li>Migration im mittleren TB-Bereich für ca. 500 Benutzer</li>
					<li>Strukturierung von Berechtigungen und Datenablagen</li>
					<li>Begleitung der Anwender und Anpassung bestehender Arbeitsprozesse an M365</li>
				</ul>
			</section>

			<!-- KONTAKT -->
			<section id="kontakt">
				<h2>Kontakt</h2>
				<p>
					Für Projektanfragen:
					<a href="mailto:info@markusstoll.cloud">info@markusstoll.cloud</a>
				</p>
			</section>

		</main>

		<Footer />

		<script>
			document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
				anchor.addEventListener('click', function (event) {
					event.preventDefault();

					const targetId = this.getAttribute('href');
					const target = document.querySelector(targetId);

					if (!target) return;

					window.scrollTo({
						top: target.offsetTop - 80,
						behavior: 'smooth'
					});

					history.pushState(null, '', targetId);
				});
			});
		</script>
	</body>
</html>

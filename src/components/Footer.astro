---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {today.getFullYear()} Markus Stoll. Alle Rechte vorbehalten.</p>

		<div class="footer-links">
			<a href="mailto:info@markusstoll.cloud">info@markusstoll.cloud</a>
			<span>·</span>
			<a href="tel:+4915140076528">0151 / 400 76 528</a>
			<span>·</span>
			<a href="#kontakt">Kontakt</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em;
		background: #020617;
		color: #94a3b8;
		border-top: 1px solid #1e293b;
		text-align: center;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
	}

	footer p {
		margin: 0 0 0.75em 0;
		font-size: 0.9em;
	}

	.footer-links {
		display: flex;
		justify-content: center;
		gap: 0.6em;
		flex-wrap: wrap;
		font-size: 0.9em;
	}

	.footer-links a {
		color: #3b82f6;
		text-decoration: none;
	}

	.footer-links a:hover {
		text-decoration: underline;
	}

	.footer-links span {
		color: #475569;
	}
</style>

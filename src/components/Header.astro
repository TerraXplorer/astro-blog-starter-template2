---
---

<header>
	<nav>
		<div class="brand">
			<a href="/">Markus Stoll</a>
			<span>Microsoft 365 / Intune Consultant</span>
		</div>

		<div class="internal-links">
			<a href="#profil">Profil</a>
			<a href="#leistungen">Leistungen</a>
			<a href="#projekte">Projekte</a>
			<a href="#kontakt">Kontakt</a>
		</div>

		<a class="button primary" href="mailto:info@markusstoll.cloud">
			Projekt anfragen
		</a>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		width: 100%;
		background: #020617;
		border-bottom: 1px solid #1e293b;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
	}

	nav {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		min-height: 64px;
		padding: 0 1rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		box-sizing: border-box;
	}

	.brand {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.brand a {
		color: #f9fafb;
		text-decoration: none;
		font-weight: 700;
		line-height: 1.1;
	}

	.brand span {
		color: #94a3b8;
		font-size: 0.8rem;
		line-height: 1.2;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 1.25rem;
	}

	.internal-links a {
		color: #e5e7eb;
		text-decoration: none;
		position: relative;
		white-space: nowrap;
	}

	.internal-links a:hover {
		color: #3b82f6;
	}

	.internal-links a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		width: 0;
		height: 2px;
		background: #3b82f6;
		transition: width 0.2s ease;
	}

	.internal-links a:hover::after {
		width: 100%;
	}

	.button {
		display: inline-block;
		padding: 0.6rem 1rem;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}

	.button.primary {
		background: #3b82f6;
		color: #ffffff !important;
		border: 1px solid #3b82f6;
		transition: background 0.2s ease, border-color 0.2s ease;
	}

	.button.primary:hover {
		background: #2563eb;
		border-color: #2563eb;
		color: #ffffff !important;
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.internal-links {
			display: none;
		}
	}

	@media (max-width: 768px) {
		nav {
			min-height: 56px;
			padding: 0 0.85rem;
		}

		.brand a {
			font-size: 0.95rem;
		}

		.brand span {
			font-size: 0.72rem;
		}

		.button {
			display: none;
		}
	}
</style>

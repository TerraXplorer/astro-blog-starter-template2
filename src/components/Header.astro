---
---

<header>
	<nav>
		<h2>
			<a href="/">Markus Stoll</a>
			<span class="subtitle">Microsoft 365 / Intune Consultant</span>
		</h2>

		<div class="internal-links">
			<a href="#profil">Profil</a>
			<a href="#leistungen">Leistungen</a>
			<a href="#projekte">Projekte</a>
			<a href="#kontakt">Kontakt</a>
		</div>

		<div class="contact-links">
			<a class="button primary" href="mailto:info@markusstoll.cloud">
				Projekt anfragen
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		margin: 0;
		padding: 0 1em;
		background: #020617;
		border-bottom: 1px solid #1e293b;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		max-width: 1100px;
		margin: 0 auto;
		min-height: 64px;
	}

	h2 {
		margin: 0;
		display: flex;
		flex-direction: column;
		font-size: 1em;
	}

	h2 a {
		text-decoration: none;
		font-weight: 700;
		color: #f9fafb;
	}

	.subtitle {
		font-size: 0.8em;
		color: #94a3b8;
	}

	.internal-links a {
		margin: 0 10px;
		text-decoration: none;
		color: #e5e7eb;
		position: relative;
	}

	.internal-links a:hover {
		color: #3b82f6;
	}

	.internal-links a::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		width: 0;
		height: 2px;
		background: #3b82f6;
		transition: width 0.2s ease;
	}

	.internal-links a:hover::after {
		width: 100%;
	}

	.contact-links {
		font-size: 0.9em;
		color: #94a3b8;
		white-space: nowrap;
	}

	.contact-links a {
		text-decoration: none;
		color: #3b82f6;
	}

	.button {
		display: inline-block;
		padding: 0.6rem 1rem;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}

	.button.primary {
		background: #3b82f6;
		color: #ffffff !important;
		border: 1px solid #3b82f6;
		transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
	}

	.button.primary:hover {
		background: #2563eb;
		border-color: #2563eb;
		color: #ffffff !important;
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.internal-links {
			display: none;
		}
	}

	@media (max-width: 768px) {
		header {
			padding: 0 0.75em;
		}

		nav {
			flex-direction: column;
			align-items: flex-start;
			justify-content: center;
			gap: 10px;
			padding: 12px 0;
			min-height: auto;
		}

		h2 {
			font-size: 0.95rem;
		}

		.subtitle {
			font-size: 0.75rem;
		}

		.contact-links {
			width: 100%;
			display: block;
			white-space: normal;
		}

		.button {
			width: 100%;
			text-align: center;
			padding: 0.7rem 1rem;
		}
	}
</style>

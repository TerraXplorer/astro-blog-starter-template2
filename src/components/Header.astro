---
---

<header class="site-header">
	<nav class="nav">
		<div class="brand">
			<a href="/">Markus Stoll</a>
			<span>Microsoft 365 / Intune Consultant</span>
		</div>

		<div class="desktop-links">
			<a href="#profil">Profil</a>
			<a href="#leistungen">Leistungen</a>
			<a href="#projekte">Projekte</a>
			<a href="#kontakt">Kontakt</a>
		</div>

		<a class="button primary desktop-cta" href="mailto:info@markusstoll.cloud">
			Projekt anfragen
		</a>

		<details class="mobile-menu">
			<summary>Menü</summary>
			<div class="mobile-links">
				<a href="#profil">Profil</a>
				<a href="#leistungen">Leistungen</a>
				<a href="#projekte">Projekte</a>
				<a href="#kontakt">Kontakt</a>
				<a class="button primary" href="mailto:info@markusstoll.cloud">Projekt anfragen</a>
			</div>
		</details>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 1000;

		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);

		background: #020617;
		border-bottom: 1px solid #1e293b;
		box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
	}

	.nav {
		width: 100%;
		max-width: 1100px;
		margin: 0 auto;
		min-height: 64px;
		padding: 0 1rem;
		box-sizing: border-box;

		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.brand a {
		color: #f9fafb;
		text-decoration: none;
		font-weight: 700;
		line-height: 1.1;
	}

	.brand span {
		color: #94a3b8;
		font-size: 0.8rem;
		line-height: 1.2;
	}

	.desktop-links {
		display: flex;
		gap: 1.25rem;
	}

	.desktop-links a {
		color: #e5e7eb;
		text-decoration: none;
		white-space: nowrap;
	}

	.desktop-links a:hover {
		color: #3b82f6;
	}

	.button {
		display: inline-block;
		padding: 0.6rem 1rem;
		border-radius: 8px;
		font-size: 0.9rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}

	.button.primary {
		background: #3b82f6;
		color: #ffffff !important;
		border: 1px solid #3b82f6;
	}

	.button.primary:hover {
		background: #2563eb;
		border-color: #2563eb;
		text-decoration: none;
	}

	.mobile-menu {
		display: none;
		position: relative;
	}

	.mobile-menu summary {
		color: #f9fafb;
		cursor: pointer;
		list-style: none;
		font-weight: 600;
	}

	.mobile-menu summary::-webkit-details-marker {
		display: none;
	}

	.mobile-links {
		position: absolute;
		right: 0;
		top: 42px;
		min-width: 220px;

		display: flex;
		flex-direction: column;
		gap: 0.75rem;

		padding: 1rem;
		background: #020617;
		border: 1px solid #1e293b;
		border-radius: 10px;
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
	}

	.mobile-links a {
		color: #e5e7eb;
		text-decoration: none;
	}

	.mobile-links a:hover {
		color: #3b82f6;
	}

	@media (max-width: 900px) {
		.desktop-links,
		.desktop-cta {
			display: none;
		}

		.mobile-menu {
			display: block;
		}

		.nav {
			min-height: 56px;
		}
	}

	@media (max-width: 480px) {
		.brand a {
			font-size: 0.95rem;
		}

		.brand span {
			font-size: 0.72rem;
		}

		.mobile-links {
			right: 0;
			min-width: 200px;
		}
	}
</style>
